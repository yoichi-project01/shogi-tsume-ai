# Copy this file to .env.local and fill in the values from your Supabase project settings.

# Safe to expose to the browser (RLS must be configured on every table).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Used for future AI-generated hints/explanations/puzzles.
OPENAI_API_KEY=

# Safe to expose to the browser once AdSense is approved.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
